<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- Nordberg child parkas -->

	<!-- Basic boy/girl parkas -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergBoy" or defName="Apparel_ROE_NordbergGirl"]/statBases</xpath>
		<value>
			<Bulk>5</Bulk>
			<WornBulk>2.5</WornBulk>
		</value>
	</Operation>
  
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergBoy" or defName="Apparel_ROE_NordbergGirl"]/statBases/Mass</xpath>
		<value>
			<Mass>1</Mass>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergBoy" or defName="Apparel_ROE_NordbergGirl"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>0.27</ArmorRating_Sharp>
		</value>
	</Operation>
  
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergBoy" or defName="Apparel_ROE_NordbergGirl"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>0.19</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationRemove">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergBoy" or defName="Apparel_ROE_NordbergGirl"]/equippedStatOffsets</xpath>
	</Operation>
	
	<!-- Fancy girls parka -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergWitchGirl"]/statBases</xpath>
		<value>
			<Bulk>5</Bulk>
			<WornBulk>2.5</WornBulk>
		</value>
	</Operation>

