		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergWitchGirl"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>0.29</ArmorRating_Sharp>
		</value>
	</Operation>
  
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergWitchGirl"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>0.21</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergWitchGirl"]/statBases/Mass</xpath>
		<value>
			<Mass>1.5</Mass>
		</value>
	</Operation>
  
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergWitchGirl"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>0.31</ArmorRating_Sharp>
		</value>
	</Operation>
  
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergWitchGirl"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>0.21</ArmorRating_Blunt>
		</value>
	</Operation>
	
	<!-- Outcast's Parka-->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergWitchBoy"]/statBases</xpath>
		<value>
			<Bulk>5</Bulk>
			<WornBulk>2.5</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergWitchBoy"]/statBases/ArmorRating_Sharp</xpath>
