	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergWitchBoy"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>0.21</ArmorRating_Blunt>
		</value>
	</Operation>

</Patch>
