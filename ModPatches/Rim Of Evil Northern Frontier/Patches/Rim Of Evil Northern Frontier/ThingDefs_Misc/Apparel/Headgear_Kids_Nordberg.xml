<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- Nordberg child headgear   -->

	<!-- Basic boys/girls hoods:-->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergBoyHood" or defName="Apparel_ROE_NordbergGirlHood"]/statBases</xpath>
		<value>
			<Bulk>1</Bulk>
		</value>
	</Operation>
  
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergBoyHood" or defName="Apparel_ROE_NordbergGirlHood"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>0.14</ArmorRating_Sharp>
		</value>
	</Operation>
  
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergBoyHood" or defName="Apparel_ROE_NordbergGirlHood"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>0.06</ArmorRating_Blunt>
		</value>
	</Operation>

	<!-- Outcast's Hood -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergWitchBoyHood"]/statBases</xpath>
		<value>
			<Bulk>1</Bulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergWitchBoyHood"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>0.16</ArmorRating_Sharp>
		</value>
	</Operation>
  
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergWitchBoyHood"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>0.11</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergWitchBoyHood"]/equippedStatOffsets/MeleeHitChance</xpath>
		<value>
			<MeleeHitChance>0.04</MeleeHitChance>
		</value>
	</Operation>
  
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergWitchBoyHood"]/equippedStatOffsets/ToxicEnvironmentResistance</xpath>
		<value>
			<ToxicEnvironmentResistance>0.10</ToxicEnvironmentResistance>
			<SmokeSensitivity>-0.1</SmokeSensitivity>
		</value>
	</Operation>
	
	<!-- Child earmuffs -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergEarmuffs"]/statBases</xpath>
		<value>
			<Bulk>0.35</Bulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergEarmuffs"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>0.02</ArmorRating_Sharp>
		</value>
	</Operation>
  
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergEarmuffs"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>0.01</ArmorRating_Blunt>
		</value>
	</Operation>
  
</Patch>
