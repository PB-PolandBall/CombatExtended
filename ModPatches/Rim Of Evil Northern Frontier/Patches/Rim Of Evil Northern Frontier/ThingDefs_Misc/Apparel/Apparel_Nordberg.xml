<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- Adult Nordberg parkas -->
	
	<!-- Basic Nordberg fur parkas -->
	
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergA" or defName="Apparel_ROE_NordbergB"]/statBases</xpath>
		<value>
			<Bulk>12</Bulk>
			<WornBulk>5.5</WornBulk>
		</value>
	</Operation>
  
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergA" or defName="Apparel_ROE_NordbergB"]/statBases/Mass</xpath>
		<value>
			<Mass>3.6</Mass>
		</value>
	</Operation>
  
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergA" or defName="Apparel_ROE_NordbergB"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>0.36</ArmorRating_Sharp>
		</value>
	</Operation>
  
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergA" or defName="Apparel_ROE_NordbergB"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>0.26</ArmorRating_Blunt>
		</value>
	</Operation>
	
	<!-- Hunter's Parka:-->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergHunter"]/statBases</xpath>
		<value>
			<Bulk>12</Bulk>
			<WornBulk>5.5</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergHunter"]/statBases/MaxHitPoints</xpath>
		<value>
			<MaxHitPoints>190</MaxHitPoints>
		</value>
	</Operation>
  
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergHunter"]/statBases/Mass</xpath>
		<value>
			<Mass>5.2</Mass>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergHunter"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>0.4</ArmorRating_Sharp>
		</value>
	</Operation>
  
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergHunter"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>0.3</ArmorRating_Blunt>
		</value>
	</Operation>
  
	<Operation Class="PatchOperationRemove">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergHunter"]/equippedStatOffsets/MoveSpeed</xpath>
	</Operation>
	
	<!-- Northern Mistress Dress -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergMistress"]/statBases</xpath>
		<value>
			<Bulk>6</Bulk>
			<WornBulk>2</WornBulk>
		</value>
	</Operation>
  
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergMistress"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>0.24</ArmorRating_Sharp>
		</value>
	</Operation>
  
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_ROE_NordbergMistress"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>0.12</ArmorRating_Blunt>
		</value>
	</Operation>
  
</Patch>
