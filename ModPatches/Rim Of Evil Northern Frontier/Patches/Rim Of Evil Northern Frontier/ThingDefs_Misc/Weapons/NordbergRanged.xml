<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- ========================= -->
	<!-- Nordberg ranged xHarpoonx -->
	<!-- ========================= -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Nordberg_ROE_Harpoon"]</xpath>
		<value>
			<ThingDef Class="CombatExtended.AmmoDef" ParentName="BaseWeaponAndAmmoNeolithic">
				<defName>Nordberg_ROE_Harpoon</defName>
				<label>hunting harpoons</label>
				<description>Large throwing harpoons used by the hunter tribes of the north, intended to wound and bleed out larger prey.</description>
				<graphicData>
					<texPath>Things/Item/Equipment/WeaponRanged/HunterHarpoon</texPath>
					<graphicClass>Graphic_Single</graphicClass>
					<drawSize>1</drawSize>
					<onGroundRandomRotateAngle>0</onGroundRandomRotateAngle>
				</graphicData>
				<soundInteract>Interact_BeatFire</soundInteract>
				<statBases>
					<MaxHitPoints>130</MaxHitPoints>
					<Flammability>0.35</Flammability>
					<DeteriorationRate>2</DeteriorationRate>
					<SellPriceFactor>0.5</SellPriceFactor>

					<SightsEfficiency>0.85</SightsEfficiency>
					<ShotSpread>1.8</ShotSpread>
					<SwayFactor>3.1</SwayFactor>
					<Bulk>5.75</Bulk>
					<Mass>3.50</Mass>
					<RangedWeapon_Cooldown>1.45</RangedWeapon_Cooldown>
					<MeleeCounterParryBonus>0.24</MeleeCounterParryBonus>
				</statBases>
				<equippedAngleOffset>45</equippedAngleOffset>
				<equippedStatOffsets>
					<MeleeCritChance>0.20</MeleeCritChance>
					<MeleeParryChance>0.40</MeleeParryChance>
					<MeleeDodgeChance>0.42</MeleeDodgeChance>
					<HuntingStealth>0.05</HuntingStealth>
					<FishingSpeed MayRequire="Ludeon.RimWorld.Odyssey">0.1</FishingSpeed>
				</equippedStatOffsets>
				<stackLimit>10</stackLimit>
				<weaponTags>
					<li>NeolithicRangedHeavy</li>
					<li>CE_Pila</li>
					<li>CE_OneHandedWeapon</li>
				</weaponTags>
				<weaponClasses>
					<li>Ranged</li>
				</weaponClasses>
				<tradeability>All</tradeability>
				<verbs>
					<li Class="CombatExtended.VerbPropertiesCE">
						<verbClass>CombatExtended.Verb_ShootCEOneUse</verbClass>
						<hasStandardCommand>true</hasStandardCommand>
						<defaultProjectile>NordbergHarpoon_Thrown</defaultProjectile>
						<warmupTime>1.2</warmupTime>
						<range>10.5</range>
					</li>
				</verbs>
				<tools>
					<li Class="CombatExtended.ToolCE">
						<label>shaft</label>
						<capacities>
							<li>Blunt</li>
						</capacities>
						<power>7</power>
						<cooldownTime>1.95</cooldownTime>
						<armorPenetrationBlunt>2.20</armorPenetrationBlunt>
						<linkedBodyPartsGroup>Shaft</linkedBodyPartsGroup>
					</li>
					<li Class="CombatExtended.ToolCE">
						<label>point</label>
						<capacities>
							<li>Stab</li>
						</capacities>
						<power>16</power>
						<cooldownTime>1.75</cooldownTime>
						<chanceFactor>1.45</chanceFactor>
						<armorPenetrationBlunt>2.20</armorPenetrationBlunt>
						<armorPenetrationSharp>0.85</armorPenetrationSharp>
						<linkedBodyPartsGroup>Point</linkedBodyPartsGroup>
					</li>
				</tools>
				<ammoClass>NordbergHarpoon</ammoClass>
			</ThingDef>
		</value>
	</Operation>

<Operation Class="PatchOperationReplace">
	<xpath>Defs/ThingDef[defName="NordbergHarpoon_Thrown"]</xpath>
	<value>
		<ThingDef ParentName="BaseProjectileNeolithic">
			<defName>NordbergHarpoon_Thrown</defName>
			<label>harpoon (thrown)</label>
			<graphicData>
				<texPath>Things/Item/Equipment/WeaponRanged/HunterHarpoon_Projectile</texPath>
				<graphicClass>Graphic_Single</graphicClass>
			</graphicData>
			<projectile Class="CombatExtended.ProjectilePropertiesCE">
				<damageDef>RangedStab</damageDef>
				<gravityFactor>1.7</gravityFactor>
				<damageAmountBase>26</damageAmountBase>
				<speed>12.8</speed>
				<armorPenetrationBlunt>11.0</armorPenetrationBlunt>
				<armorPenetrationSharp>4.5</armorPenetrationSharp>
				<preExplosionSpawnChance>0.75</preExplosionSpawnChance>
				<preExplosionSpawnThingDef>Nordberg_ROE_Harpoon</preExplosionSpawnThingDef>
			</projectile>
		</ThingDef>
	</value>
</Operation>

</Patch>
