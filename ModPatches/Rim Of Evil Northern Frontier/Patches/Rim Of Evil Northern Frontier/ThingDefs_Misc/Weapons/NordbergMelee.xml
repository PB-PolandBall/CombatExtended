<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- ========================= -->
	<!-- Nordberg melee           -->
	<!-- ========================= -->

	<!-- Hunter's Club -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="MeleeWeapon_ROE_HuntersClub"]/statBases</xpath>
		<value>
			<Bulk>3.5</Bulk>
			<MeleeCounterParryBonus>0.16</MeleeCounterParryBonus>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="MeleeWeapon_ROE_HuntersClub"]/equippedStatOffsets</xpath>
		<value>
			<equippedStatOffsets>
				<ArrestSuccessChance>0.01</ArrestSuccessChance>
				<AnimalGatherSpeed>0.02</AnimalGatherSpeed>
				<TameAnimalChance>0.02</TameAnimalChance>
				<TrainAnimalChance>0.02</TrainAnimalChance>
				<BondAnimalChanceFactor>-0.05</BondAnimalChanceFactor>
				<MeleeCritChance>0.22</MeleeCritChance>
				<MeleeParryChance>0.16</MeleeParryChance>
				<MeleeDodgeChance>0.08</MeleeDodgeChance>
			</equippedStatOffsets>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="MeleeWeapon_ROE_HuntersClub"]/weaponTags</xpath>
		<value>
			<li>CE_OneHandedWeapon</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="MeleeWeapon_ROE_HuntersClub"]/tools</xpath>
		<value>
			<tools>
				<li Class="CombatExtended.ToolCE">
					<label>handle</label>
					<capacities>
						<li>Poke</li>
					</capacities>
					<power>2</power>
					<cooldownTime>1.55</cooldownTime>
					<chanceFactor>0.10</chanceFactor>
					<armorPenetrationBlunt>0.45</armorPenetrationBlunt>
					<linkedBodyPartsGroup>Handle</linkedBodyPartsGroup>
				</li>
				<li Class="CombatExtended.ToolCE">
					<label>head</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>16</power>
					<cooldownTime>1.82</cooldownTime>
					<chanceFactor>0.90</chanceFactor>
					<armorPenetrationBlunt>4.40</armorPenetrationBlunt>
					<linkedBodyPartsGroup>Head</linkedBodyPartsGroup>
				</li>
			</tools>
		</value>
	</Operation>

</Patch>
