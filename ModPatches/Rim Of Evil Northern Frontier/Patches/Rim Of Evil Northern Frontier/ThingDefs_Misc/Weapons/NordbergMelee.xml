<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- Nordberg melee -->

	<!-- Hunter's Club -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="MeleeWeapon_ROE_HuntersClub"]/statBases</xpath>
		<value>
			<Bulk>3.5</Bulk>
			<MeleeCounterParryBonus>0.16</MeleeCounterParryBonus>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="MeleeWeapon_ROE_HuntersClub"]/equippedStatOffsets</xpath>
		<value>
			<MeleeCritChance>0.71</MeleeCritChance>
			<MeleeParryChance>0.14</MeleeParryChance>
			<MeleeDodgeChance>0.15</MeleeDodgeChance>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="MeleeWeapon_ROE_HuntersClub"]/weaponTags</xpath>
		<value>
			<li>CE_OneHandedWeapon</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="MeleeWeapon_ROE_HuntersClub"]/tools</xpath>
		<value>
			<tools>
				<li Class="CombatExtended.ToolCE">
					<label>handle</label>
					<capacities>
						<li>Poke</li>
					</capacities>
					<power>3</power>
					<cooldownTime>1.75</cooldownTime>
					<chanceFactor>0.10</chanceFactor>
					<armorPenetrationBlunt>0.55</armorPenetrationBlunt>
					<linkedBodyPartsGroup>Handle</linkedBodyPartsGroup>
				</li>
				<li Class="CombatExtended.ToolCE">
					<label>head</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>18</power>
					<cooldownTime>2.02</cooldownTime>
					<chanceFactor>0.90</chanceFactor>
					<armorPenetrationBlunt>4.80</armorPenetrationBlunt>
					<linkedBodyPartsGroup>Head</linkedBodyPartsGroup>
				</li>
			</tools>
		</value>
	</Operation>

</Patch>
