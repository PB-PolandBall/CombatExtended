<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- ========================= -->
	<!-- Nordbergian Rabbit        -->
	<!-- ========================= -->

	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/ThingDef[@Name="BaseHareNordberg"]</xpath>
		<value>
			<li Class="CombatExtended.RacePropertiesExtensionCE">
				<bodyShape>Quadruped</bodyShape>
			</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[@Name="BaseHareNordberg"]/statBases/MoveSpeed</xpath>
		<value>
			<MoveSpeed>6.5</MoveSpeed>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[@Name="BaseHareNordberg"]/statBases</xpath>
		<value>
			<ArmorRating_Sharp>0.15</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.22</ArmorRating_Blunt>
			<MeleeDodgeChance>0.18</MeleeDodgeChance>
			<MeleeCritChance>0.04</MeleeCritChance>
			<MeleeParryChance>0.02</MeleeParryChance>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[@Name="BaseHareNordberg"]/tools</xpath>
		<value>
			<tools>
				<li Class="CombatExtended.ToolCE">
					<capacities>
						<li>Bite</li>
					</capacities>
					<power>3.5</power>
					<cooldownTime>1.85</cooldownTime>
					<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
					<chanceFactor>1.0</chanceFactor>
					<armorPenetrationSharp>0.25</armorPenetrationSharp>
					<armorPenetrationBlunt>0.75</armorPenetrationBlunt>
				</li>
				<li Class="CombatExtended.ToolCE">
					<label>head</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>1.5</power>
					<cooldownTime>2.0</cooldownTime>
					<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
					<chanceFactor>0.2</chanceFactor>
					<armorPenetrationBlunt>0.35</armorPenetrationBlunt>
				</li>
			</tools>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/PawnKindDef[defName="Nordberg_ROE_Snowhare"]</xpath>
		<value>
			<combatPower>18</combatPower>
		</value>
	</Operation>

	<!-- ========================= -->
	<!-- Nordbergian Seal          -->
	<!-- ========================= -->

	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/ThingDef[defName="Nordberg_ROE_Seal"]</xpath>
		<value>
			<li Class="CombatExtended.RacePropertiesExtensionCE">
				<bodyShape>Quadruped</bodyShape>
			</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Nordberg_ROE_Seal"]/statBases/MoveSpeed</xpath>
		<value>
			<MoveSpeed>2.4</MoveSpeed>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Nordberg_ROE_Seal"]/statBases</xpath>
		<value>
			<ArmorRating_Sharp>0.9</ArmorRating_Sharp>
			<ArmorRating_Blunt>1.4</ArmorRating_Blunt>
			<MeleeDodgeChance>0.08</MeleeDodgeChance>
			<MeleeCritChance>0.10</MeleeCritChance>
			<MeleeParryChance>0.04</MeleeParryChance>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Nordberg_ROE_Seal"]/tools</xpath>
		<value>
			<tools>
				<li Class="CombatExtended.ToolCE">
					<label>tusk</label>
					<capacities>
						<li>Scratch</li>
						<li>Stab</li>
					</capacities>
					<power>12</power>
					<cooldownTime>2.25</cooldownTime>
					<linkedBodyPartsGroup>TuskAttackTool</linkedBodyPartsGroup>
					<chanceFactor>1.1</chanceFactor>
					<armorPenetrationSharp>1.20</armorPenetrationSharp>
					<armorPenetrationBlunt>4.50</armorPenetrationBlunt>
				</li>
				<li Class="CombatExtended.ToolCE">
					<capacities>
						<li>Bite</li>
					</capacities>
					<power>11</power>
					<cooldownTime>1.85</cooldownTime>
					<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
					<chanceFactor>0.8</chanceFactor>
					<armorPenetrationSharp>0.90</armorPenetrationSharp>
					<armorPenetrationBlunt>4.00</armorPenetrationBlunt>
				</li>
				<li Class="CombatExtended.ToolCE">
					<label>head</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>8</power>
					<cooldownTime>2.1</cooldownTime>
					<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
					<chanceFactor>0.2</chanceFactor>
					<armorPenetrationBlunt>2.20</armorPenetrationBlunt>
				</li>
			</tools>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="Nordberg_ROE_SealPup"]/combatPower</xpath>
		<value>
			<combatPower>20</combatPower>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="Nordberg_ROE_Seal"]/combatPower</xpath>
		<value>
			<combatPower>95</combatPower>
		</value>
	</Operation>

</Patch>