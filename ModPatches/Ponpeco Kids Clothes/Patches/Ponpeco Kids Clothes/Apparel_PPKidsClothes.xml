<?xml version="1.0" encoding="utf-8"?>
<Patch>

    <Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Apparel_PKCBackpack"]/statBases</xpath>
		<value>
			<Bulk>1.5</Bulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_PKCBackpack"]/equippedStatOffsets</xpath>
		<value>
			<equippedStatOffsets>
				<CarryBulk>20</CarryBulk>
			</equippedStatOffsets>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_PKCBackpack"]/apparel/bodyPartGroups</xpath>
		<value>
			<bodyPartGroups>
				<li>Shoulders</li>
			</bodyPartGroups>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_PKCBackpack"]/apparel/layers</xpath>
		<value>
			<layers>
				<li>Backpack</li>
			</layers>
		</value>
	</Operation>

	<!-- Equivalent to Romper-->
    <Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[@Name="PKCApparelMakeableBase"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>1.5</StuffEffectMultiplierArmor>
			<Bulk>1</Bulk>
		</value>
	</Operation>

	<!-- Equivalent to Parka-->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[@Name="PKCApparelOuterMakeableBase"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>3</StuffEffectMultiplierArmor>
			<Bulk>5</Bulk>
			<WornBulk>2.5</WornBulk>
		</value>
	</Operation>

	<!-- Equivalent to Cowboy hat-->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[@Name="PKCHatMakeableBase"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>2</StuffEffectMultiplierArmor>
		</value>
	</Operation>

	<!-- Equivalent to Tuque-->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_PKCCheckedHood"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>2</StuffEffectMultiplierArmor>
		</value>
	</Operation>

	<!-- Equivalent to Steel Helmet for Kids-->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Apparel_PKCHeroHelmet"]/statBases</xpath>
		<value>
			<Bulk>3</Bulk>
			<WornBulk>0.75</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_PKCHeroHelmet"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>2.5</StuffEffectMultiplierArmor>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_PKCHeroHelmet"]/stuffCategories/li[.="Metallic"]</xpath>
		<value>
			<li>Steeled</li>
		</value>
	</Operation>
	
	<!-- Vacsuit helms-->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Apparel_PKCVacsuitHelmetA" or defName="Apparel_PKCVacsuitHelmetB"]/statBases</xpath>
		<value>
			<Bulk>4</Bulk>
			<WornBulk>1</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_PKCVacsuitHelmetA" or defName="Apparel_PKCVacsuitHelmetB"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>3.5</ArmorRating_Sharp>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_PKCVacsuitHelmetA" or defName="Apparel_PKCVacsuitHelmetB"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>7</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Apparel_PKCVacsuitHelmetA" or defName="Apparel_PKCVacsuitHelmetB"]/equippedStatOffsets</xpath>
		<value>
			<SmokeSensitivity>-1</SmokeSensitivity>
		</value>
	</Operation>

	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/ThingDef[defName="Apparel_PKCVacsuitHelmetA" or defName="Apparel_PKCVacsuitHelmetB"]</xpath>
		<value>
			<li Class="CombatExtended.PartialArmorExt">
				<stats>
					<li>
						<ArmorRating_Sharp>0.70</ArmorRating_Sharp>
						<parts>
							<li>Eye</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Blunt>0.70</ArmorRating_Blunt>
						<parts>
							<li>Eye</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Sharp>0.50</ArmorRating_Sharp>
						<parts>
							<li>Nose</li>
							<li>Jaw</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Blunt>0.50</ArmorRating_Blunt>
						<parts>
							<li>Nose</li>
							<li>Jaw</li>
						</parts>
					</li>
				</stats>
			</li>
		</value>
	</Operation>

	<!-- Vacsuits-->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Apparel_PKCVacsuitChildrenA" or defName="Apparel_PKCVacsuitChildrenB"]/statBases</xpath>
		<value>
			<Bulk>40</Bulk>
			<WornBulk>6</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_PKCVacsuitChildrenA" or defName="Apparel_PKCVacsuitChildrenB"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>2.65</ArmorRating_Sharp>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_PKCVacsuitChildrenA" or defName="Apparel_PKCVacsuitChildrenB"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>5.25</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Apparel_PKCVacsuitChildrenA" or defName="Apparel_PKCVacsuitChildrenB"]/apparel/bodyPartGroups</xpath>
		<value>
			<li>Hands</li>
			<li>Feet</li>
		</value>
	</Operation>

</Patch>