<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/Asimov.PawnDef[@Name="OuterRim_BaseHumanoidDroid"]</xpath>
		<value>
			<li Class="CombatExtended.RacePropertiesExtensionCE">
				<bodyShape>Humanoid</bodyShape>
			</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/Asimov.PawnDef[@Name="OuterRim_BaseHumanoidDroid"]/statBases</xpath>
		<value>
			<MeleeDodgeChance>1</MeleeDodgeChance>
			<MeleeCritChance>1</MeleeCritChance>
			<MeleeParryChance>1</MeleeParryChance>
			<SmokeSensitivity>0</SmokeSensitivity>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[@Name="BaseAnimalDroid"]/statBases</xpath>
		<value>
			<SmokeSensitivity>0</SmokeSensitivity>
		</value>
	</Operation>

	<!-- give all basic humanoid droids the same basic tool set -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/Asimov.PawnDef[
			defName="OuterRim_BattleDroid" or
			defName="OuterRim_BattleDroidAdvanced" or
			defName="OuterRim_MagnaGuardDroid" or
			defName="OuterRim_ProtocolDroid" or
			defName="OuterRim_CommandoDroid" or
			defName="OuterRim_HKDroid" or
			defName="OuterRim_SuperTacticalDroid" or
			defName="OuterRim_TacticalDroid" or
			defName="OuterRim_DUMDroid"
			]/tools</xpath>
		<value>
			<tools>
				<li Class="CombatExtended.ToolCE">
					<label>left fist</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>4</power>
					<cooldownTime>1.26</cooldownTime>
					<linkedBodyPartsGroup>LeftHand</linkedBodyPartsGroup>
					<armorPenetrationSharp>0.5</armorPenetrationSharp>
					<armorPenetrationBlunt>0.5</armorPenetrationBlunt>
				</li>
				<li Class="CombatExtended.ToolCE">
					<label>right fist</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>4</power>
					<cooldownTime>1.26</cooldownTime>
					<linkedBodyPartsGroup>RightHand</linkedBodyPartsGroup>
					<armorPenetrationSharp>0.5</armorPenetrationSharp>
					<armorPenetrationBlunt>0.5</armorPenetrationBlunt>
				</li>
				<li Class="CombatExtended.ToolCE">
					<label>head</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>3</power>
					<cooldownTime>4.49</cooldownTime>
					<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
					<chanceFactor>0.2</chanceFactor>
					<armorPenetrationSharp>0.625</armorPenetrationSharp>
					<armorPenetrationBlunt>0.625</armorPenetrationBlunt>
				</li>
			</tools>
		</value>
	</Operation>

	<!-- except SBDs and imperial heavies, who get a beefed up melee and no headbutt -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/Asimov.PawnDef[
			defName="OuterRim_SuperBattleDroid" or
			defName="OuterRim_ImperialLaborDroid" or
			defName="OuterRim_KXSecurityDroid"
			]/tools</xpath>
		<value>
			<tools>
				<li Class="CombatExtended.ToolCE">
					<label>left fist</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>12</power>
					<cooldownTime>1.26</cooldownTime>
					<linkedBodyPartsGroup>LeftHand</linkedBodyPartsGroup>
					<armorPenetrationSharp>1</armorPenetrationSharp>
					<armorPenetrationBlunt>24</armorPenetrationBlunt>
				</li>
				<li Class="CombatExtended.ToolCE">
					<label>right fist</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>12</power>
					<cooldownTime>1.26</cooldownTime>
					<linkedBodyPartsGroup>RightHand</linkedBodyPartsGroup>
					<armorPenetrationSharp>1</armorPenetrationSharp>
					<armorPenetrationBlunt>24</armorPenetrationBlunt>
				</li>
			</tools>
		</value>
	</Operation>
	
	<!-- and most nonhuman droids get a simple "powertool" attack -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[
			defName="OuterRim_MuckrakerDroid" or
			defName="OuterRim_FX7Droid" or
			defName="OuterRim_GNKDroid" or
			defName="OuterRim_MSEDroid" or
			defName="OuterRim_SalvageAssistDroid" or
			defName="OuterRim_AstromechDroid"
			]/tools</xpath>
		<value>
			<tools>
				<li Class="CombatExtended.ToolCE">
					<label>powertool</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>4</power>
					<cooldownTime>1.26</cooldownTime>
					<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
					<armorPenetrationSharp>0.5</armorPenetrationSharp>
					<armorPenetrationBlunt>0.5</armorPenetrationBlunt>
				</li>
			</tools>
		</value>
	</Operation>
	
	<!-- except astromechs and droidekas, who get a weak headbutt -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="OuterRim_DestroyerDroid"]/tools</xpath>
		<value>
			<tools>
				<li Class="CombatExtended.ToolCE">
					<label>head</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>3</power>
					<cooldownTime>4.49</cooldownTime>
					<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
					<chanceFactor>0.2</chanceFactor>
					<armorPenetrationSharp>0.625</armorPenetrationSharp>
					<armorPenetrationBlunt>0.625</armorPenetrationBlunt>
				</li>
			</tools>
		</value>
	</Operation>

	<Operation Class="PatchOperationConditional">
		<xpath>Defs/Asimov.PawnDef[@Name="OuterRim_BaseHumanoidDroid"]/comps</xpath>
		<nomatch Class="PatchOperationAdd">
			<xpath>Defs/Asimov.PawnDef[@Name="OuterRim_BaseHumanoidDroid"]</xpath>
			<value>
				<comps />
			</value>
		</nomatch>
	</Operation>

	<Operation Class="PatchOperationConditional">
		<xpath>Defs/ThingDef[@Name="BaseAnimalDroid"]/comps</xpath>
		<nomatch Class="PatchOperationAdd">
			<xpath>Defs/ThingDef[@Name="BaseAnimalDroid"]</xpath>
			<value>
				<comps />
			</value>
		</nomatch>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/Asimov.PawnDef[@Name="OuterRim_BaseHumanoidDroid"]/comps</xpath>
		<value>
			<li>
				<compClass>CombatExtended.CompPawnGizmo</compClass>
			</li>
			<li Class="CombatExtended.CompProperties_ArmorDurability">
				<Durability>500</Durability>
				<Regenerates>true</Regenerates>
				<RegenInterval>600</RegenInterval>
				<RegenValue>5</RegenValue>
				<MinArmorPct>0.5</MinArmorPct>
			</li>
			<!-- I didn't insert the suppressability comp for the base pawntype, because they're, well, droids -->
			<li>
				<compClass>CombatExtended.CompAmmoGiver</compClass>
			</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[@Name="BaseAnimalDroid"]/comps</xpath>
		<value>
			<li>
				<compClass>CombatExtended.CompPawnGizmo</compClass>
			</li>
			<li Class="CombatExtended.CompProperties_ArmorDurability">
				<Durability>500</Durability>
				<Regenerates>true</Regenerates>
				<RegenInterval>600</RegenInterval>
				<RegenValue>5</RegenValue>
				<MinArmorPct>0.5</MinArmorPct>
			</li>
			<!-- I didn't insert the suppressability comp for the base pawntype, because they're, well, droids -->
			<li>
				<compClass>CombatExtended.CompAmmoGiver</compClass>
			</li>
		</value>
	</Operation>

	<!-- Tactical Droids, on the other hand, are smart enough to take cover -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/Asimov.PawnDef[defName="OuterRim_TacticalDroid" or defName="OuterRim_SuperTacticalDroid"]/comps</xpath>
		<value>
			<li Class="CombatExtended.CompProperties_Suppressable" />
		</value>
	</Operation>

</Patch>