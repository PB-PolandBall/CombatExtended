<?xml version="1.0" encoding="utf-8" ?>
<Patch>
	<!-- ============================ Outfit ============================ -->	
	
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Apparel_Nagan_Outfit"]/statBases</xpath>
		<value>
			<Bulk>3</Bulk>
			<WornBulk>2</WornBulk>
		</value>
	</Operation>
	
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_Nagan_Outfit"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>6</ArmorRating_Sharp>
		</value>
	</Operation>	
	
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_Nagan_Outfit"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>3</ArmorRating_Blunt>
		</value>
	</Operation>
	
	<!-- ============================ Hat ============================ -->	
	
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Nagan_Hat"]/statBases</xpath>
		<value>
			<Bulk>1</Bulk>
			<WornBulk>1</WornBulk>
		</value>
	</Operation>
	
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Nagan_Hat"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>10</StuffEffectMultiplierArmor>
			<ArmorRating_Sharp>2</ArmorRating_Sharp>
		</value>
	</Operation>	

	<!-- ============================ Headphones ============================ -->	
	
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Nagan_Headphones"]/statBases</xpath>
		<value>
			<Bulk>1</Bulk>
			<WornBulk>1</WornBulk>
		</value>
	</Operation>
	
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Nagan_Headphones"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<ArmorRating_Sharp>2</ArmorRating_Sharp>
		</value>
	</Operation>

</Patch>